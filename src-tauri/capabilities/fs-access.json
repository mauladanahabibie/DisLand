{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "fs-access",
  "description": "File system access for profile import/export",
  "windows": ["main"],
  "permissions": [
    "dialog:allow-save",
    "dialog:allow-open",
    "fs:allow-write-text-file",
    "fs:allow-read-text-file",
    {
      "identifier": "fs:scope",
      "allow": [{ "path": "**" }]
    }
  ]
}
